{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|elif|else|each|while|struct)\\b",
    "decreaseIndentPattern": "^\\s*(end|else|elif)\\b"
  },
  "folding": {
    "markers": {
      "start": "^\\s*(fn|struct|if|each|while)\\b",
      "end": "^\\s*end\\b"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
