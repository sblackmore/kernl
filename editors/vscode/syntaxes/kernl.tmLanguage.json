{
  "name": "kernl",
  "scopeName": "source.kernl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.kernl"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.kernl",
      "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.kernl" }]
    },
    "numbers": {
      "patterns": [
        { "match": "\\b[0-9]+\\.[0-9]+\\b", "name": "constant.numeric.float.kernl" },
        { "match": "\\b[0-9]+\\b", "name": "constant.numeric.integer.kernl" }
      ]
    },
    "keywords": {
      "match": "\\b(fn|in|out|inv|do|let|mut|if|elif|else|end|each|while|struct|mod|use|mode|intent|confidence|fallback|guarantee)\\b",
      "name": "keyword.control.kernl"
    },
    "operators": {
      "match": "\\b(add|sub|mul|div|mod|eq|neq|gt|lt|gte|lte|and|or|not)\\b",
      "name": "keyword.operator.kernl"
    },
    "builtins": {
      "match": "\\b(filter|reduce|map|max|min|len|print|abs|sqrt|concat|range)\\b",
      "name": "support.function.builtin.kernl"
    },
    "types": {
      "match": "\\b(int|uint|float|bool|str|void)\\b",
      "name": "storage.type.kernl"
    },
    "functions": {
      "match": "(?<=fn\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "entity.name.function.kernl"
    },
    "constants": {
      "match": "\\b(true|false|strict|fluid)\\b",
      "name": "constant.language.kernl"
    }
  }
}
